NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_NAVER_OAUTH_PROVIDER=custom:naver
# 네이버 로그인(백엔드 커스텀 OAuth). 네이버 개발자센터 앱 등록 후 채운다.
# 콜백 URL(개발자센터에 등록): https://mirilook.com/api/auth/naver/callback
NAVER_LOGIN_CLIENT_ID=
NAVER_LOGIN_CLIENT_SECRET=
# 위 키가 준비되면 "true"로 켜야 로그인 화면에 네이버 버튼이 활성화된다.
NEXT_PUBLIC_NAVER_LOGIN_ENABLED=false
# 홈의 결과 미리보기(남/여) 탭 + 가이드라인 영상 노출 여부. 특허 출원 기간 동안 숨김(미설정=숨김).
# 특허 등록 완료 후 다시 공개하려면 "true"로 설정 후 재배포.
NEXT_PUBLIC_SHOW_HOME_PREVIEW=false
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_CONSULTATION_BUCKET=MIRILOOK-consultations
AI_PROVIDER=mock
AI_PROVIDER_API_KEY=
OPENAI_API_KEY=
OPENAI_RECOMMENDATION_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=low
OPENAI_IMAGE_COMPRESSION=70
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_PREVIEW_IMAGE_SIZE=1024x1024
OPENAI_ANGLE_IMAGE_SIZE=1024x1024
MIRILOOK_FINAL_IMAGE_PROVIDER=openai
MIRILOOK_FINAL_IMAGE_FALLBACK=openai
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3-pro-image
GEMINI_IMAGE_ASPECT_RATIO=1:1
GEMINI_IMAGE_SIZE=1K
RESEND_API_KEY=
RESEND_FROM_EMAIL=MIRILOOK <hello@mirilook.com>
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=proj_MIRILOOK_mirror
TRIGGER_API_BASE_URL=https://api.trigger.dev
